# ═══════════════════════════════════════════════
# 微信贾维斯 环境变量模板
# 复制为 .env 并填入真实值
# cp .env.example .env
# ═══════════════════════════════════════════════

# DeepSeek（纯文本大脑 - 必填）
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 多模态图片大模型（阿里云 DashScope - 图片识别用）
DASHSCOPE_API_KEY=sk-your_dashscope_key_here

# 内网穿透工具：auto（自动探测，cpolar 优先）| cpolar | ngrok
TUNNEL_PROVIDER=auto

# 教务系统爬虫（选填 - 用于自动抓取课表）
CRAWLER_LOGIN_URL=
CRAWLER_USERNAME=
CRAWLER_PASSWORD=
